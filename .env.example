# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.

# Supabase project — find these in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used by Next.js when deploying to a subpath (e.g. GitHub Pages at /LondonLC).
# Leave blank for local development so the site serves from /.
NEXT_PUBLIC_BASE_PATH=
